@model RegisterEmployerViewModel
@{
    ViewData["Title"] = "Employer Registration";
}

<h1 class="h3 mb-3">Create Employer Account</h1>

<form method="post" action="/account/register/employer" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" type="password" class="form-control" />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="OrganizationName" class="form-label"></label>
        <input asp-for="OrganizationName" class="form-control" />
        <span asp-validation-for="OrganizationName" class="text-danger small"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Industry" class="form-label"></label>
        <input asp-for="Industry" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="Website" class="form-label"></label>
        <input asp-for="Website" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="Location" class="form-label"></label>
        <input asp-for="Location" class="form-control" />
    </div>

    <div class="col-12">
        <button class="btn btn-primary" type="submit">Register Employer</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
