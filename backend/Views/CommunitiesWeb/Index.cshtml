@model IReadOnlyList<Community>
@{
    ViewData["Title"] = "Communities";
    var createModel = (CreateCommunityViewModel?)ViewData["CreateModel"] ?? new CreateCommunityViewModel();
    var joinedCommunityIds = (HashSet<long>?)ViewData["JoinedCommunityIds"] ?? new HashSet<long>();
}

<div class="row g-4">
    <div class="col-lg-7">
        <h1 class="h3 mb-3">Communities</h1>

        @if (Model.Count == 0)
        {
            <div class="alert alert-info">No communities yet.</div>
        }
        else
        {
            <div class="list-group">
                @foreach (var community in Model)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <h2 class="h6 mb-1">@community.Name</h2>
                            <p class="small text-muted mb-0">@community.Description</p>
                        </div>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var isJoined = joinedCommunityIds.Contains(community.Id);
                            var action = isJoined ? $"/communities/{community.Id}/unjoin" : $"/communities/{community.Id}/join";
                            <form method="post" action="@action">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm community-join-btn @(isJoined ? "joined" : "not-joined")" type="submit">
                                    @if (isJoined)
                                    {
                                        <span class="label-default">Joined</span>
                                        <span class="label-hover">Unjoin</span>
                                    }
                                    else
                                    {
                                        <span>Join</span>
                                    }
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-body">
                <h2 class="h5">Create Community</h2>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form method="post" action="/communities/create" class="mt-3">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label" for="communityName">Name</label>
                            <input id="communityName" name="Name" value="@createModel.Name" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="communityDescription">Description</label>
                            <textarea id="communityDescription" name="Description" class="form-control" rows="4">@createModel.Description</textarea>
                        </div>

                        <button class="btn btn-primary" type="submit">Create</button>
                    </form>
                }
                else
                {
                    <div class="alert alert-warning mt-3">Login first to create or join communities.</div>
                }
            </div>
        </div>
    </div>
</div>
