@{
    ViewData["Title"] = "About";
}

<section class="hero-panel with-image mb-4" style="background-image: url('/img/7434657.jpg');">
    <h1 class="display-6 fw-bold mb-3">About BetterLink</h1>
    <p class="lead mb-0">BetterLink connects students to employers through jobs, communities, and direct engagement in one platform.</p>
</section>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Our Mission</h2>
                <p class="mb-0">Help students transition from campus to career while giving employers a direct channel to emerging talent.</p>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">What We Enable</h2>
                <p class="mb-0">Job applications, role-based profiles, and communities where members can collaborate around opportunities.</p>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Built For Growth</h2>
                <p class="mb-0">An API-first backend with a server-rendered web experience, designed to evolve with new features safely.</p>
            </div>
        </div>
    </div>
</div>
