@{
    ViewData["Title"] = "Services";
}

<section class="hero-panel with-image mb-4" style="background-image: url('/img/office_team.jpg');">
    <h1 class="display-6 fw-bold mb-3">Services</h1>
    <p class="lead mb-0">BetterLink offers focused workflows for students and employers with shared social and networking features.</p>
</section>

<div class="row g-4">
    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Students</h2>
                <p class="mb-0">Discover jobs, apply quickly, and track progress from one dashboard.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Employers</h2>
                <p class="mb-0">Post opportunities and connect directly with qualified student applicants.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Communities</h2>
                <p class="mb-0">Create and join topic-based groups that foster collaboration and visibility.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Profiles</h2>
                <p class="mb-0">Maintain a role-aware public profile that highlights strengths and identity.</p>
            </div>
        </div>
    </div>
</div>
